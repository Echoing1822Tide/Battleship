@page "/"
@using MauiBattleship.Models
@using MauiBattleship.Services
@inject GameService Game

<PageTitle>Battleship</PageTitle>

<div class="battleship-page">
    <div class="battleship-header">
        <h1 class="display-title">Battleship</h1>
        <div class="subtitle-row">
            <span class="subtitle">Player vs Computer</span>
            <span class="phase-label">
                Phase:
                <span class="phase-value">@GetPhaseText()</span>
            </span>
        </div>

        <div class="controls-row">
            <button class="btn primary" @onclick="OnNewGameClicked">
                NEW GAME
            </button>

            <button class="btn secondary" @onclick="OnRotateClicked">
                @GetRotateButtonText()
            </button>
        </div>

        <div class="status-banner">
            @StatusMessage
        </div>
    </div>

    <div class="boards-row">
        <!-- Player board -->
        <div class="board-card">
            <div class="board-card-header">
                <h2>Your Fleet</h2>
                <p>
                    Place ships by clicking cells while in
                    <strong>Placing Ships</strong>.
                </p>
            </div>

            <div class="board-card-body">
                @RenderBoard(Game.PlayerBoard, OnPlayerCellClick, true)
            </div>

            <div class="board-card-footer">
                Ships sunk: @Game.PlayerBoard.SunkShipCount / @Game.PlayerBoard.TotalShipCount
            </div>
        </div>

        <!-- Computer board -->
        <div class="board-card">
            <div class="board-card-header">
                <h2>Enemy Waters</h2>
                <p>
                    When it’s <strong>Your Turn</strong>, click to fire on enemy cells.
                </p>
            </div>

            <div class="board-card-body">
                @RenderBoard(Game.ComputerBoard, OnComputerCellClick, false)
            </div>

            <div class="board-card-footer">
                Ships sunk: @Game.ComputerBoard.SunkShipCount / @Game.ComputerBoard.TotalShipCount
            </div>
        </div>
    </div>
</div>

@code {
    private string StatusMessage = "Welcome to Battleship! Click New Game to begin.";
    private ShipOrientation _currentOrientation = ShipOrientation.Horizontal;

    protected override void OnInitialized()
    {
        // Keep the UI synced with GameService events
        Game.GameStateChanged += (_, _) =>
        {
            InvokeAsync(StateHasChanged);
        };

        Game.MessageReceived += (_, msg) =>
        {
            StatusMessage = msg;
            InvokeAsync(StateHasChanged);
        };
    }

    private void OnNewGameClicked()
    {
        _currentOrientation = ShipOrientation.Horizontal;
        Game.StartNewGame();

        var nextShip = Game.GetNextShipToPlace();
        if (nextShip is not null)
        {
            StatusMessage = $"Place your {nextShip.Name} ({nextShip.Size} cells).";
        }
        else
        {
            StatusMessage = "Place your ships on the board.";
        }
    }

    private void OnRotateClicked()
    {
        _currentOrientation = _currentOrientation == ShipOrientation.Horizontal
            ? ShipOrientation.Vertical
            : ShipOrientation.Horizontal;
    }

    private string GetRotateButtonText()
    {
        return _currentOrientation == ShipOrientation.Horizontal
            ? "Rotate Ship (Horizontal)"
            : "Rotate Ship (Vertical)";
    }

    private string GetPhaseText()
    {
        return Game.CurrentPhase switch
        {
            GamePhase.NotStarted   => "Not Started",
            GamePhase.PlacingShips => "Placing Ships",
            GamePhase.PlayerTurn   => "Your Turn",
            GamePhase.ComputerTurn => "Computer Turn",
            GamePhase.GameOver     => "Game Over",
            _                      => Game.CurrentPhase.ToString()
        };
    }

    private void OnPlayerCellClick(int row, int col)
    {
        // Only allow placement during PlacingShips phase
        if (Game.CurrentPhase != GamePhase.PlacingShips)
            return;

        var ship = Game.GetNextShipToPlace();
        if (ship is null)
            return;

        bool placed = Game.PlacePlayerShip(ship, row, col, _currentOrientation);
        if (!placed)
        {
            StatusMessage = "Invalid position for that ship. Try a different location or orientation.";
            StateHasChanged();
            return;
        }

        // If that was the last ship, GameService will switch to PlayerTurn and fire events
        var nextShip = Game.GetNextShipToPlace();
        if (nextShip is not null)
        {
            StatusMessage = $"Place your {nextShip.Name} ({nextShip.Size} cells).";
        }
        // If nextShip is null, GameService already sent the “All ships placed” message

        StateHasChanged();
    }

    private void OnComputerCellClick(int row, int col)
    {
        // Only allow attacks during player's turn
        if (Game.CurrentPhase != GamePhase.PlayerTurn)
            return;

        var result = Game.PlayerAttack(row, col);
        if (result is null)
            return;

        // If game already won, don't let the computer shoot
        if (Game.IsGameOver)
        {
            StateHasChanged();
            return;
        }

        // Computer takes its turn
        if (Game.CurrentPhase == GamePhase.ComputerTurn)
        {
            Game.ComputerAttack();
        }

        StateHasChanged();
    }

    private RenderFragment RenderBoard(GameBoard board, Action<int, int> onClick, bool isPlayerBoard)
        => builder =>
    {
        int seq = 0;

        builder.OpenElement(seq++, "table");
        builder.AddAttribute(seq++, "class", "board-table");

        for (int r = 0; r < GameBoard.BoardSize; r++)
        {
            builder.OpenElement(seq++, "tr");

            for (int c = 0; c < GameBoard.BoardSize; c++)
            {
                var cell = board.Cells[r, c];
                var css = GetCellClass(cell, isPlayerBoard);

                builder.OpenElement(seq++, "td");
                builder.AddAttribute(seq++, "class", css);
                builder.AddAttribute(
                    seq++,
                    "onclick",
                    EventCallback.Factory.Create(this, () => onClick(r, c))
                );
                builder.CloseElement(); // td
            }

            builder.CloseElement(); // tr
        }

        builder.CloseElement(); // table
    };

    private string GetCellClass(Cell cell, bool isPlayerBoard)
    {
        var classes = new List<string> { "board-cell" };

        if (isPlayerBoard && cell.HasShip)
        {
            classes.Add("cell-ship");
        }

        switch (cell.State)
        {
            case CellState.Hit:
                classes.Add("cell-hit");
                break;
            case CellState.Miss:
                classes.Add("cell-miss");
                break;
            case CellState.Ship when !isPlayerBoard:
                // Don’t show enemy ships directly
                break;
        }

        return string.Join(" ", classes);
    }
}
