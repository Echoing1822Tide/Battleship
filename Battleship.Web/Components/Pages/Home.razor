@page "/"
@rendermode InteractiveServer
@implements IDisposable

@inject GameService Game

<div class="page-shell">
    <div class="header">
        <h1 class="title">BATTLESHIP</h1>
        <div class="subtitle">Player vs Computer</div>
    </div>

    <div class="top-row">
        <div class="controls">
            <div class="phase">Phase: <span class="phase-badge">@Game.CurrentPhase</span></div>

            <button class="btn btn-primary" @onclick="OnNewGameClicked">NEW GAME</button>
            <button class="btn btn-secondary" @onclick="ToggleOrientation" disabled="@(!IsPlacing)">
                ROTATE SHIP (@(IsVertical ? "VERTICAL" : "HORIZONTAL"))
            </button>
        </div>

        <div class="status">
            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="status-pill">@StatusMessage</div>
            }
        </div>
    </div>

    <div class="boards">
        <div class="board-card">
            <div class="board-title">Your Fleet</div>
            <div class="board-subtitle">Place ships by clicking cells while in PlacingShips.</div>

            <div class="board-surface">
                <div class="board-grid">
                    @for (var r = 0; r < BoardSize; r++)
                    {
                        for (var c = 0; c < BoardSize; c++)
                        {
                            var cell = Game.PlayerBoard.GetCell(r, c);
                            <button
                                class="@GetCellCss(cell, isPlayerBoard: true)"
                                @onclick="() => OnPlayerCellClicked(r, c)"
                                disabled="@(!IsPlacing)">
                                @RenderCellFx(cell)
                            </button>
                        }
                    }
                </div>

                @foreach (var ship in Game.GetPlayerFleet().Where(s => s.Positions.Count > 0))
                {
                    <img class="ship-sprite"
                         src="@GetShipSpritePath(ship)"
                         style="@GetShipSpriteStyle(ship)" />
                }
            </div>

            <div class="board-footer">
                Ships sunk: @Game.PlayerBoard.ShipsSunk / 5
            </div>
        </div>

        <div class="board-card">
            <div class="board-title">Enemy Waters</div>
            <div class="board-subtitle">When it's your turn, click to fire on enemy cells.</div>

            <div class="board-surface">
                <div class="board-grid">
                    @for (var r = 0; r < BoardSize; r++)
                    {
                        for (var c = 0; c < BoardSize; c++)
                        {
                            var cell = Game.ComputerBoard.GetCell(r, c);

                            <button
                                class="@GetCellCss(cell, isPlayerBoard: false)"
                                @onclick="() => OnEnemyCellClicked(r, c)"
                                disabled="@(!IsPlayerTurn)">
                                @RenderCellFx(cell)
                            </button>
                        }
                    }
                </div>
            </div>

            <div class="board-footer">
                Ships sunk: @Game.ComputerBoard.ShipsSunk / 5
            </div>
        </div>
    </div>
</div>

@code {
    private const int BoardSize = GameBoard.BoardSize;

    // Must match CSS sizing in app.css
    private const int CellPx = 32;
    private const int GapPx = 6;

    private bool IsVertical = false;

    public string StatusMessage { get; set; } = "";

    private bool IsPlacing => Game.CurrentPhase == GamePhase.PlacingShips;
    private bool IsPlayerTurn => Game.CurrentPhase == GamePhase.PlayerTurn;

    protected override void OnInitialized()
    {
        Game.GameStateChanged += OnGameStateChanged;
        StatusMessage = "Click NEW GAME to begin placing ships.";
    }

    public void Dispose()
    {
        Game.GameStateChanged -= OnGameStateChanged;
    }

    private void OnGameStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);

        if (IsPlacing)
        {
            var next = Game.GetNextPlayerShipToPlace();
            StatusMessage = next is null
                ? "All ships placed! Game starting..."
                : $"Placing: {next.Name} (size {next.Size}). Click a starting cell.";
        }
        else if (IsPlayerTurn)
        {
            StatusMessage = "Your turn. Click on Enemy Waters to fire.";
        }
        else if (Game.CurrentPhase == GamePhase.ComputerTurn)
        {
            StatusMessage = "Computer is thinking...";
        }
        else if (Game.CurrentPhase == GamePhase.GameOver)
        {
            StatusMessage = Game.Winner == PlayerType.Human
                ? "You win! Click NEW GAME to play again."
                : "Computer wins! Click NEW GAME to try again.";
        }
    }

    private void OnNewGameClicked()
    {
        IsVertical = false;
        Game.StartNewGame();
        StatusMessage = "New game started. Place your ships on the board.";
        StateHasChanged();
    }

    private void ToggleOrientation()
    {
        IsVertical = !IsVertical;

        if (IsPlacing)
        {
            var next = Game.GetNextPlayerShipToPlace();
            if (next is not null)
                StatusMessage = $"Placing: {next.Name} (size {next.Size}). Orientation: {(IsVertical ? "Vertical" : "Horizontal")}.";
        }
    }

    private void OnPlayerCellClicked(int row, int col)
    {
        if (!IsPlacing)
            return;

        var ship = Game.GetNextPlayerShipToPlace();
        if (ship is null)
        {
            StatusMessage = "All ships placed already.";
            return;
        }

        var ok = Game.PlacePlayerShip(ship, row, col, IsVertical);
        if (!ok)
        {
            // This message is correct: you're trying to start a long ship too close to an edge or on an occupied area.
            StatusMessage = "Invalid placement. Ships cannot overlap or go off the board.";
            return;
        }

        var next = Game.GetNextPlayerShipToPlace();
        StatusMessage = next is null
            ? "All ships placed! Game starting..."
            : $"Placed! Next: {next.Name} (size {next.Size}).";
    }

    private void OnEnemyCellClicked(int row, int col)
    {
        if (!IsPlayerTurn)
        {
            StatusMessage = "Not your turn yet (or you haven't finished placing ships).";
            return;
        }

        var result = Game.PlayerAttack(row, col);

        if (result is null)
        {
            StatusMessage = "You already fired there. Pick a different cell.";
            return;
        }

        StatusMessage = result switch
        {
            AttackResult.Hit => $"HIT at {CoordLabel(row, col)}!",
            AttackResult.Sunk => $"SUNK at {CoordLabel(row, col)}!",
            AttackResult.Miss => $"Miss at {CoordLabel(row, col)}.",
            _ => "Invalid attack."
        };

        if (Game.CurrentPhase == GamePhase.ComputerTurn && !Game.IsGameOver)
        {
            Game.ComputerAttack();
        }
    }

    private static string CoordLabel(int row, int col) => $"{(char)('A' + row)}{col + 1}";

    private static string GetCellCss(Cell cell, bool isPlayerBoard)
    {
        var classes = "board-cell";

        if (cell.State == CellState.Hit) classes += " cell-hit";
        if (cell.State == CellState.Miss) classes += " cell-miss";

        if (isPlayerBoard && cell.Ship is not null)
            classes += " cell-has-ship";

        return classes;
    }

    private RenderFragment RenderCellFx(Cell cell) => builder =>
    {
        if (cell.State == CellState.Hit)
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "class", "cell-effect");
            builder.AddAttribute(2, "src", "images/ships/effects/Explosion.png");
            builder.CloseElement();
        }
        else if (cell.State == CellState.Miss)
        {
            builder.OpenElement(3, "div");
            builder.AddAttribute(4, "class", "cell-miss-dot");
            builder.CloseElement();
        }
    };

    private static string GetShipSpritePath(Ship ship)
    {
        return ship.Size switch
        {
            5 => "images/ships/Aircraft_Carrier_5_Pegs.png",
            4 => "images/ships/Battleship_4_Pegs.png",
            3 when ship.Name.Contains("Cruiser", StringComparison.OrdinalIgnoreCase) => "images/ships/Cruiser_3_Pegs.png",
            3 => "images/ships/Submarine_3_Pegs.png",
            2 => "images/ships/Destroyer_2_Pegs.png",
            _ => "images/ships/Cruiser_3_Pegs.png"
        };
    }

    private static string GetShipSpriteStyle(Ship ship)
    {
        var minRow = ship.Positions.Min(p => p.Row);
        var minCol = ship.Positions.Min(p => p.Col);
        var maxRow = ship.Positions.Max(p => p.Row);
        var maxCol = ship.Positions.Max(p => p.Col);

        var isVertical = maxRow != minRow;
        var length = ship.Size;

        // grid math
        var left = minCol * (CellPx + GapPx);
        var top = minRow * (CellPx + GapPx);

        // sprite is drawn HORIZONTAL by default
        var spriteWidth = length * CellPx + (length - 1) * GapPx;
        var spriteHeight = CellPx;

        if (!isVertical)
        {
            return $"left:{left}px; top:{top}px; width:{spriteWidth}px; height:{spriteHeight}px;";
        }

        // Vertical: rotate the horizontal sprite in place around top-left, then pull it back into the board.
        // After rotate(90deg), the width becomes "height", so we translate up by the original width.
        return $"left:{left}px; top:{top}px; width:{spriteWidth}px; height:{spriteHeight}px;" +
               $"transform-origin: top left; transform: rotate(90deg) translateY(-{spriteWidth}px);";
    }
}
