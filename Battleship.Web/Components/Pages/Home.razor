@page "/"
@using MauiBattleship.Services
@using MauiBattleship.GameCore
@using MauiBattleship.GameCore.Enums
@using MauiBattleship.GameCore.Models
@using MauiBattleship.GameCore.Ships
@inject GameService GameService

<PageTitle>Battleship</PageTitle>

<div class="game-shell">
    <header class="game-header">
        <div class="title-block">
            <div class="title">BATTLESHIP</div>
            <div class="subtitle">Player vs Computer</div>
            <div class="meta">Phase: <b>@GameService.Phase</b></div>
            <div class="status">@_statusMessage</div>
        </div>

        <div class="controls">
            <button class="btn" @onclick="StartNewGame">NEW GAME</button>
            <button class="btn"
                    @onclick="ToggleOrientation"
                    disabled="@(GameService.Phase != GamePhase.PlacingShips || _modalOpen)">
                ROTATE SHIP (@(GameService.CurrentOrientation == ShipOrientation.Horizontal ? "HORIZONTAL" : "VERTICAL"))
            </button>
        </div>
    </header>

    <main class="boards">
        <section class="board-card">
            <h3>Your Fleet</h3>
            <div class="hint">
                @if (GameService.Phase == GamePhase.PlacingShips && GameService.CurrentShipToPlace != null)
                {
                    <span>Placing: <b>@GameService.CurrentShipToPlace.Name</b> (size @GameService.CurrentShipToPlace.Size)</span>
                }
                else
                {
                    <span>Your board</span>
                }
            </div>

            <div class="board-grid">
                @for (int r = 0; r < GameBoard.BoardSize; r++)
                {
                    for (int c = 0; c < GameBoard.BoardSize; c++)
                    {
                        var row = r;
                        var col = c;
                        var cell = GameService.PlayerBoard.GetCell(row, col);

                        <button class="@GetCellCss(cell, isEnemy:false)"
                                disabled="@_modalOpen"
                                @onclick="() => OnPlayerCellClicked(row, col)">
                            @RenderCellFx(cell)
                        </button>
                    }
                }

                @RenderPlayerShipSprites()
            </div>

            <div class="footer">
                Ships sunk: @GameService.PlayerShips.Count(s => s.IsSunk) / @GameService.PlayerShips.Count
            </div>
        </section>

        <section class="board-card">
            <h3>Enemy Waters</h3>
            <div class="hint">
                @if (GameService.Phase == GamePhase.PlacingShips)
                {
                    <span>Place your fleet first.</span>
                }
                else
                {
                    <span>Click to fire.</span>
                }
            </div>

            <div class="board-grid">
                @for (int r = 0; r < GameBoard.BoardSize; r++)
                {
                    for (int c = 0; c < GameBoard.BoardSize; c++)
                    {
                        var row = r;
                        var col = c;
                        var cell = GameService.EnemyBoard.GetCell(row, col);

                        <button class="@GetCellCss(cell, isEnemy:true)"
                                disabled="@(GameService.Phase != GamePhase.PlayerTurn || _modalOpen)"
                                @onclick="() => OnEnemyCellClicked(row, col)">
                            @RenderCellFx(cell)
                        </button>
                    }
                }
            </div>

            <div class="footer">
                Enemy ships sunk: @GameService.EnemyShips.Count(s => s.IsSunk) / @GameService.EnemyShips.Count
            </div>
        </section>
    </main>
</div>

@if (_modalOpen)
{
    <div class="modal-overlay">
        <div class="modal-bubble">
            <div class="modal-title">@_modalTitle</div>
            <div class="modal-body">@_modalBody</div>
            <div class="modal-actions">
                <button class="btn btn-primary" @onclick="CloseModalAsync">@_modalButtonText</button>
            </div>
        </div>
    </div>
}

@code
{
    private string _statusMessage = "Ready.";
    private bool _disposed;

    // Modal state
    private bool _modalOpen;
    private string _modalTitle = "";
    private string _modalBody = "";
    private string _modalButtonText = "OK";
    private Func<Task>? _modalOnClose;

    // Timing knobs
    private const int PlayerShotDelayMs = 250;
    private const int EnemyShotDelayMs = 450;

    protected override void OnInitialized()
    {
        GameService.OnChanged += OnGameStateChanged;
        GameService.NewGame();
        _statusMessage = "New game started. Place your ships on your board.";
    }

    private void OnGameStateChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        GameService.OnChanged -= OnGameStateChanged;
    }

    private void StartNewGame()
    {
        GameService.NewGame();
        _statusMessage = "New game started. Place your ships on your board.";
        CloseModalImmediate();
    }

    private void ToggleOrientation()
    {
        GameService.ToggleOrientation();
    }

    private void OnPlayerCellClicked(int row, int col)
    {
        if (_modalOpen) return;

        if (GameService.Phase != GamePhase.PlacingShips)
            return;

        bool placed = GameService.TryPlaceNextPlayerShip(row, col);

        if (!placed)
        {
            _statusMessage = "Invalid placement. Try a different spot.";
            return;
        }

        if (GameService.Phase == GamePhase.PlayerTurn)
        {
            _statusMessage = "All ships placed. Your turn!";
        }
        else if (GameService.CurrentShipToPlace != null)
        {
            _statusMessage = $"Placed. Next: {GameService.CurrentShipToPlace.Name} (size {GameService.CurrentShipToPlace.Size})";
        }
    }

    private async Task OnEnemyCellClicked(int row, int col)
    {
        if (_modalOpen) return;

        if (GameService.Phase != GamePhase.PlayerTurn)
            return;

        var before = GameService.EnemyBoard.GetCell(row, col).State;

        var playerShot = GameService.PlayerAttack(row, col);

        // If they clicked a previously-fired cell, don’t pop a modal—just update status.
        var after = GameService.EnemyBoard.GetCell(row, col).State;
        if (before == after && (after == CellState.Miss || after == CellState.Hit))
        {
            _statusMessage = $"You already fired at ({row},{col}).";
            return;
        }

        await Task.Delay(PlayerShotDelayMs);

        bool playerHit = after == CellState.Hit;
        string? enemyShipName = playerHit ? FindShipNameAt(GameService.EnemyShips, row, col) : null;

        if (GameService.Phase == GamePhase.GameOver)
        {
            // Player ended the game
            ShowGameOverModal(playerWon: true);
            return;
        }

        if (playerHit)
        {
            var namePart = string.IsNullOrWhiteSpace(enemyShipName) ? "their ship" : $"their {enemyShipName}";
            ShowModal(
                title: "DIRECT HIT!",
                body: $"You hit {namePart} at ({row},{col}).",
                buttonText: "Enemy Turn",
                onClose: EnemyAttackSequenceAsync
            );
        }
        else
        {
            ShowModal(
                title: "SPLASH!",
                body: $"YOU MISSED!! ({row},{col})",
                buttonText: "Enemy Turn",
                onClose: EnemyAttackSequenceAsync
            );
        }

        _statusMessage = $"You fired at ({row},{col}): {playerShot.Message}";
    }

    private async Task EnemyAttackSequenceAsync()
    {
        if (GameService.Phase != GamePhase.EnemyTurn && GameService.Phase != GamePhase.PlayerTurn)
            return;

        // If your GameService already flips to EnemyTurn, this still works.
        _statusMessage = "Enemy is thinking...";
        StateHasChanged();

        await Task.Delay(EnemyShotDelayMs);

        var enemyResult = GameService.EnemyAttackRandom();
        var cellState = GameService.PlayerBoard.GetCell(enemyResult.Row, enemyResult.Col).State;

        bool enemyHit = cellState == CellState.Hit;
        string? playerShipName = enemyHit ? FindShipNameAt(GameService.PlayerShips, enemyResult.Row, enemyResult.Col) : null;

        if (GameService.Phase == GamePhase.GameOver)
        {
            // Enemy ended the game
            ShowGameOverModal(playerWon: false);
            _statusMessage = $"Enemy fired at ({enemyResult.Row},{enemyResult.Col}): {enemyResult.Message}";
            return;
        }

        if (enemyHit)
        {
            var namePart = string.IsNullOrWhiteSpace(playerShipName) ? "your ship" : $"your {playerShipName}";
            ShowModal(
                title: "WE'VE BEEN HIT!",
                body: $"Enemy fired at ({enemyResult.Row},{enemyResult.Col}): Hit! ({namePart})",
                buttonText: "Fire Back!",
                onClose: () => Task.CompletedTask
            );
        }
        else
        {
            ShowModal(
                title: "ENEMY MISSED!",
                body: $"Enemy fired at ({enemyResult.Row},{enemyResult.Col}): Miss!",
                buttonText: "Enemy Missed!",
                onClose: () => Task.CompletedTask
            );
        }

        _statusMessage = $"Enemy fired at ({enemyResult.Row},{enemyResult.Col}): {enemyResult.Message}";
    }

    private void ShowGameOverModal(bool playerWon)
    {
        string title = playerWon ? "VICTORY!" : "DEFEAT!";
        string body = playerWon ? "You Won the War!" : "You Lost the War! Your fleet was destroyed.";

        ShowModal(
            title: title,
            body: body,
            buttonText: "New Game",
            onClose: () =>
            {
                StartNewGame();
                return Task.CompletedTask;
            }
        );
    }

    private void ShowModal(string title, string body, string buttonText, Func<Task> onClose)
    {
        _modalTitle = title;
        _modalBody = body;
        _modalButtonText = buttonText;
        _modalOnClose = onClose;
        _modalOpen = true;
        StateHasChanged();
    }

    private async Task CloseModalAsync()
    {
        if (!_modalOpen) return;

        _modalOpen = false;
        var handler = _modalOnClose;
        _modalOnClose = null;

        StateHasChanged();

        if (handler != null)
            await handler();
    }

    private void CloseModalImmediate()
    {
        _modalOpen = false;
        _modalOnClose = null;
    }

    private string GetCellCss(Cell cell, bool isEnemy)
    {
        // Enemy board: hide ships until hit
        if (isEnemy && cell.State == CellState.Ship)
            return "cell cell--water";

        return cell.State switch
        {
            CellState.Empty => "cell cell--water",
            CellState.Ship => "cell cell--ship",
            CellState.Miss => "cell cell--miss",
            CellState.Hit => "cell cell--hit",
            _ => "cell cell--water"
        };
    }

    private RenderFragment RenderCellFx(Cell cell) => builder =>
    {
        // Explosion for hits, simple ripple for miss
        if (cell.State == CellState.Hit)
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "class", "fx fx-explosion");
            builder.AddAttribute(2, "src", "images/ships/effects/Explosion.png");
            builder.AddAttribute(3, "alt", "Hit");
            builder.CloseElement();
        }
        else if (cell.State == CellState.Miss)
        {
            builder.OpenElement(10, "div");
            builder.AddAttribute(11, "class", "fx fx-miss");
            builder.CloseElement();
        }
    };

    private RenderFragment RenderPlayerShipSprites() => builder =>
    {
        foreach (var ship in GameService.PlayerShips)
        {
            if (!ship.IsPlaced || ship.Positions.Count == 0)
                continue;

            var first = ship.Positions[0];
            var last = ship.Positions[^1];

            bool horizontal = first.Row == last.Row;
            int row = first.Row;
            int col = first.Col;

            string fileKey = GetShipSpriteFileKey(ship);
            string src = $"images/ships/{fileKey}.png";

            string style = BuildShipSpriteStyle(row, col, ship.Size, horizontal);

            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "class", "ship-sprite");
            builder.AddAttribute(2, "src", src);
            builder.AddAttribute(3, "style", style);
            builder.AddAttribute(4, "alt", ship.Name);
            builder.CloseElement();
        }
    };

    private static string GetShipSpriteFileKey(ShipBase ship)
    {
        // Your exact wwwroot names (no horizontal/vertical variants)
        return ship switch
        {
            Carrier => "Aircraft_Carrier_5_Pegs",
            Battleship => "Battleship_4_Pegs",
            Cruiser => "Cruiser_3_Pegs",
            Submarine => "Submarine_3_Pegs",
            Destroyer => "Destroyer_2_Pegs",
            _ => "Cruiser_3_Pegs"
        };
    }

    private static string BuildShipSpriteStyle(int row, int col, int size, bool horizontal)
    {
        // Must match app.css:
        // --cell: 32px; --gap: 6px;
        const int cell = 32;
        const int gap = 6;

        int x = col * (cell + gap);
        int y = row * (cell + gap);

        int width = horizontal ? (size * cell + (size - 1) * gap) : cell;
        int height = horizontal ? cell : (size * cell + (size - 1) * gap);

        // If vertical, rotate the same image 90 degrees.
        // We translate by its height so it “drops” into the grid instead of swinging out of bounds.
        if (!horizontal)
        {
            return $"left:{x}px; top:{y}px; width:{width}px; height:{height}px; transform: rotate(90deg) translateY(-{width}px);";
        }

        return $"left:{x}px; top:{y}px; width:{width}px; height:{height}px;";
    }

    private static string? FindShipNameAt(IEnumerable<ShipBase> ships, int row, int col)
    {
        foreach (var s in ships)
        {
            if (!s.IsPlaced) continue;
            if (s.Positions.Any(p => p.Row == row && p.Col == col))
                return s.Name;
        }
        return null;
    }
}
