@page "/"
@using MauiBattleship.Models
@using MauiBattleship.Services
@inject GameService GameService

<PageTitle>Battleship</PageTitle>

<div class="game-shell">
    <header class="game-header">
        <div class="title-block">
            <div class="title">BATTLESHIP</div>
            <div class="subtitle">Player vs Computer</div>
            <div class="meta">Phase: <b>@GameService.Phase</b></div>
            <div class="status">@_statusMessage</div>
        </div>

        <div class="controls">
            <button class="btn" @onclick="StartNewGame">NEW GAME</button>

            <button class="btn"
                    @onclick="ToggleOrientation"
                    disabled="@(GameService.Phase != GamePhase.PlacingShips)">
                ROTATE SHIP (@(GameService.CurrentPlacementIsVertical ? "VERTICAL" : "HORIZONTAL"))
            </button>
        </div>
    </header>

    <main class="boards">
        <section class="board-card">
            <h3>Your Fleet</h3>
            <div class="hint">
                @if (GameService.Phase == GamePhase.PlacingShips && GameService.CurrentShipToPlace != null)
                {
                    <span>Placing: <b>@GameService.CurrentShipToPlace.Name</b> (size @GameService.CurrentShipToPlace.Size)</span>
                }
                else
                {
                    <span>Your board</span>
                }
            </div>

            <div class="board-grid">
                @for (int r = 0; r < 10; r++)
                {
                    for (int c = 0; c < 10; c++)
                    {
                        var row = r;
                        var col = c;
                        var cell = GameService.PlayerBoard.GetCell(row, col);

                        <button class="@GetCellCss(cell, isEnemy:false)"
                                @onclick="() => OnPlayerCellClicked(row, col)">
                            @RenderCellFx(cell)
                        </button>
                    }
                }

                @RenderPlayerShipSprites()
            </div>

            <div class="footer">
                Ships sunk: @GameService.PlayerShips.Count(s => s.IsSunk) / @GameService.PlayerShips.Count
            </div>
        </section>

        <section class="board-card">
            <h3>Enemy Waters</h3>
            <div class="hint">
                @if (GameService.Phase == GamePhase.PlacingShips)
                {
                    <span>Place your fleet first.</span>
                }
                else
                {
                    <span>Click to fire.</span>
                }
            </div>

            <div class="board-grid">
                @for (int r = 0; r < 10; r++)
                {
                    for (int c = 0; c < 10; c++)
                    {
                        var row = r;
                        var col = c;
                        var cell = GameService.EnemyBoard.GetCell(row, col);

                        <button class="@GetCellCss(cell, isEnemy:true)"
                                disabled="@(_modalOpen || GameService.Phase != GamePhase.PlayerTurn)"
                                @onclick="() => OnEnemyCellClicked(row, col)">
                            @RenderCellFx(cell)
                        </button>
                    }
                }
            </div>

            <div class="footer">
                Enemy ships sunk: @GameService.EnemyShips.Count(s => s.IsSunk) / @GameService.EnemyShips.Count
            </div>
        </section>
    </main>
</div>

@if (_modalOpen)
{
    <div class="modal-backdrop">
        <div class="modal-card">
            <div class="modal-title">@_modalTitle</div>
            <div class="modal-body">@_modalBody</div>

            <button class="btn modal-btn" @onclick="CloseModalAsync">@_modalButtonText</button>
        </div>
    </div>
}

@code {
    private string _statusMessage = "Click NEW GAME to begin.";
    private bool _modalOpen;

    private string _modalTitle = "";
    private string _modalBody = "";
    private string _modalButtonText = "OK";
    private Func<Task>? _modalOnClose;

    private const int CellPx = 32;
    private const int GapPx = 6;
    private const int GridPaddingPx = 14;
    private static int StepPx => CellPx + GapPx;

    protected override void OnInitialized()
    {
        StartNewGame();
    }

    private void StartNewGame()
    {
        GameService.StartNewGame();
        _statusMessage = "Place your fleet. Click your board to place ships.";
        _modalOpen = false;
    }

    private void ToggleOrientation()
    {
        GameService.ToggleOrientation();
        _statusMessage = $"Orientation: {(GameService.CurrentPlacementIsVertical ? "VERTICAL" : "HORIZONTAL")}";
    }

    private void OnPlayerCellClicked(int row, int col)
    {
        if (_modalOpen) return;

        if (GameService.Phase != GamePhase.PlacingShips)
            return;

        bool placed = GameService.TryPlaceNextPlayerShip(row, col);

        if (!placed)
        {
            _statusMessage = "Invalid placement. Try a different spot.";
            return;
        }

        if (GameService.Phase == GamePhase.PlayerTurn)
        {
            _statusMessage = "All ships placed. Your turn!";
            ShowModal(
                title: "YOUR TURN",
                body: "All ships are deployed. Open fire!",
                buttonText: "FIRE!",
                onClose: () => Task.CompletedTask
            );
        }
        else if (GameService.CurrentShipToPlace != null)
        {
            _statusMessage = $"Placed. Next: {GameService.CurrentShipToPlace.Name} (size {GameService.CurrentShipToPlace.Size})";
        }
    }

    private Task OnEnemyCellClicked(int row, int col)
    {
        if (_modalOpen) return Task.CompletedTask;

        if (GameService.Phase != GamePhase.PlayerTurn)
            return Task.CompletedTask;

        var result = GameService.PlayerAttack(row, col);

        if (result.Message == "Already attacked.")
        {
            _statusMessage = $"You already fired at ({row},{col}).";
            return Task.CompletedTask;
        }

        if (GameService.Phase == GamePhase.GameOver)
        {
            ShowGameOverModal(playerWon: true);
            return Task.CompletedTask;
        }

        if (result.IsHit)
        {
            var shipText = string.IsNullOrWhiteSpace(result.ShipName) ? "their ship" : $"their {result.ShipName}";
            ShowModal(
                title: "DIRECT HIT!",
                body: $"You hit {shipText} at ({row},{col}).",
                buttonText: "ENEMY TURN",
                onClose: EnemyAttackSequenceAsync
            );
        }
        else
        {
            ShowModal(
                title: "SPLASH!",
                body: $"YOU MISSED!! ({row},{col})",
                buttonText: "ENEMY TURN",
                onClose: EnemyAttackSequenceAsync
            );
        }

        _statusMessage = $"You fired at ({row},{col}): {result.Message}";
        return Task.CompletedTask;
    }

    private Task EnemyAttackSequenceAsync()
    {
        if (GameService.Phase != GamePhase.EnemyTurn)
            return Task.CompletedTask;

        var enemy = GameService.EnemyAttackRandom();

        if (GameService.Phase == GamePhase.GameOver)
        {
            ShowGameOverModal(playerWon: false);
            _statusMessage = $"Enemy fired at ({enemy.Row},{enemy.Col}): {enemy.Message}";
            return Task.CompletedTask;
        }

        if (enemy.IsHit)
        {
            var shipText = string.IsNullOrWhiteSpace(enemy.ShipName) ? "your ship" : $"your {enemy.ShipName}";
            ShowModal(
                title: "ENEMY HIT!",
                body: $"Enemy fired at ({enemy.Row},{enemy.Col}): HIT on {shipText}.",
                buttonText: "FIRE BACK!",
                onClose: () => Task.CompletedTask
            );
        }
        else
        {
            ShowModal(
                title: "ENEMY MISSED!",
                body: $"Enemy fired at ({enemy.Row},{enemy.Col}): Miss!",
                buttonText: "FIRE BACK!",
                onClose: () => Task.CompletedTask
            );
        }

        _statusMessage = $"Enemy fired at ({enemy.Row},{enemy.Col}): {enemy.Message}";
        return Task.CompletedTask;
    }

    private void ShowGameOverModal(bool playerWon)
    {
        if (playerWon)
        {
            ShowModal(
                title: "YOU WON THE WAR!",
                body: "Enemy fleet destroyed.",
                buttonText: "NEW GAME",
                onClose: () => { StartNewGame(); return Task.CompletedTask; }
            );
        }
        else
        {
            ShowModal(
                title: "YOU LOST THE WAR!",
                body: "Your fleet was destroyed.",
                buttonText: "NEW GAME",
                onClose: () => { StartNewGame(); return Task.CompletedTask; }
            );
        }
    }

    private void ShowModal(string title, string body, string buttonText, Func<Task> onClose)
    {
        _modalTitle = title;
        _modalBody = body;
        _modalButtonText = buttonText;
        _modalOnClose = onClose;
        _modalOpen = true;
        StateHasChanged();
    }

    private async Task CloseModalAsync()
    {
        _modalOpen = false;
        StateHasChanged();

        if (_modalOnClose is not null)
            await _modalOnClose.Invoke();

        _modalOnClose = null;
        StateHasChanged();
    }

    private string GetCellCss(Cell cell, bool isEnemy)
    {
        var state = cell.State;

        if (isEnemy && state == CellState.Ship)
            state = CellState.Water;

        return state switch
        {
            CellState.Water => "cell cell--water",
            CellState.Ship  => "cell cell--ship",
            CellState.Miss  => "cell cell--miss",
            CellState.Hit   => "cell cell--hit",
            _ => "cell"
        };
    }

    private RenderFragment RenderCellFx(Cell cell) => builder =>
    {
        if (cell.State == CellState.Hit)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "fx fx-hit");
            builder.CloseElement();
        }
        else if (cell.State == CellState.Miss)
        {
            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "fx fx-miss");
            builder.CloseElement();
        }
    };

    private RenderFragment RenderPlayerShipSprites() => builder =>
    {
        foreach (var ship in GameService.PlayerShips.Where(s => s.IsPlaced))
        {
            int minRow = ship.Positions.Min(p => p.Row);
            int minCol = ship.Positions.Min(p => p.Col);
            int maxRow = ship.Positions.Max(p => p.Row);
            int maxCol = ship.Positions.Max(p => p.Col);

            bool vertical = (maxRow - minRow) >= (maxCol - minCol);

            int length = ship.Size;

            int widthPx = vertical ? CellPx : (CellPx * length + GapPx * (length - 1));
            int heightPx = vertical ? (CellPx * length + GapPx * (length - 1)) : CellPx;

            int left = GridPaddingPx + (minCol * StepPx);
            int top  = GridPaddingPx + (minRow * StepPx);

            string src = GetShipImagePath(ship);

            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "class", "ship-sprite");
            builder.AddAttribute(2, "src", src);
            builder.AddAttribute(3, "alt", ship.Name);
            builder.AddAttribute(4, "style", $"left:{left}px; top:{top}px; width:{widthPx}px; height:{heightPx}px;");
            builder.CloseElement();
        }
    };

    private static string GetShipImagePath(Ship ship)
    {
        return ship.Name switch
        {
            "Aircraft Carrier" => "images/Aircraft_Carrier_5_Pegs.png",
            "Battleship"       => "images/Battleship_4_Pegs.png",
            "Cruiser"          => "images/Cruiser_3_Pegs.png",
            "Submarine"        => "images/Submarine_3_Pegs.png",
            "Destroyer"        => "images/Destroyer_2_Pegs.png",
            _ => "images/Battleship_4_Pegs.png"
        };
    }
}
