@page "/"
@using MauiBattleship.Services
@using MauiBattleship.Models
@inject GameService Game

<div class="page-shell">
    <div class="header">
        <h1 class="title">BATTLESHIP</h1>
        <div class="subtitle">Player vs Computer</div>
    </div>

    <div class="top-row">
        <div class="controls">
            <div class="phase">
                Phase:
                <span class="phase-badge">@Game.CurrentPhase</span>
            </div>

            <button class="btn btn-primary" @onclick="NewGame">NEW GAME</button>
            <button class="btn btn-secondary" @onclick="ToggleOrientation">
                ROTATE SHIP (@(IsVertical ? "VERTICAL" : "HORIZONTAL"))
            </button>
        </div>

        <div class="status">
            <div class="status-pill">@StatusMessage</div>
        </div>
    </div>

    <div class="boards">
        <!-- Player board -->
        <div class="board-card">
            <div class="board-title">Your Fleet</div>
            <div class="board-subtitle">Place ships by clicking cells while in PlacingShips.</div>

            <div class="board-surface">
                <div class="board-grid">
                    @for (var r = 0; r < BoardSize; r++)
                    {
                        @for (var c = 0; c < BoardSize; c++)
                        {
                            // IMPORTANT: avoid any closure weirdness in Razor lambdas
                            var row = r;
                            var col = c;

                            var cell = Game.PlayerBoard.GetCell(row, col);

                            <button class="@GetCellClass(cell, isPlayerBoard: true)"
                                    @onclick="() => OnPlayerCellClicked(row, col)">
                                @RenderCell(cell)
                            </button>
                        }
                    }
                </div>

                @foreach (var ship in Game.GetPlayerFleet().Where(s => s.Positions.Count > 0))
                {
                    <img class="ship-sprite"
                         src="@GetShipSpritePath(ship)"
                         style="@GetShipSpriteStyle(ship)" />
                }
            </div>

            <div class="board-footer">
                Ships placed: @Game.GetPlayerFleet().Count(s => s.Positions.Count > 0) / @Game.GetPlayerFleet().Count
            </div>
        </div>

        <!-- Enemy board -->
        <div class="board-card">
            <div class="board-title">Enemy Waters</div>
            <div class="board-subtitle">When it's your turn, click to fire on enemy cells.</div>

            <div class="board-surface">
                <div class="board-grid">
                    @for (var r = 0; r < BoardSize; r++)
                    {
                        @for (var c = 0; c < BoardSize; c++)
                        {
                            var row = r;
                            var col = c;

                            var cell = Game.EnemyBoard.GetCell(row, col);

                            <button class="@GetCellClass(cell, isPlayerBoard: false)"
                                    disabled="@(Game.CurrentPhase != GamePhase.PlayerTurn)"
                                    @onclick="() => OnEnemyCellClicked(row, col)">
                                @RenderCell(cell)
                            </button>
                        }
                    }
                </div>
            </div>

            <div class="board-footer">
                Ships sunk: @Game.EnemyBoard.ShipsSunk / @TotalShips
            </div>
        </div>
    </div>
</div>

@code {
    private const int BoardSize = 10;

    // Match these to your CSS values
    private const int CellPx = 32;
    private const int GapPx = 6;
    private const int StepPx = CellPx + GapPx;

    private int TotalShips => Game.GetPlayerFleet()?.Count ?? 0;

    private bool IsVertical = false;
    private string StatusMessage = "Click NEW GAME to begin placing ships.";

    private bool IsPlacing => Game.CurrentPhase == GamePhase.PlacingShips;

    protected override void OnInitialized()
    {
        // Make sure we start in a sane state
        StatusMessage = "Click NEW GAME to begin placing ships.";
    }

    private void NewGame()
    {
        Game.StartNewGame();
        IsVertical = false;

        var next = Game.GetNextPlayerShipToPlace();
        StatusMessage = next is null
            ? "No ships to place."
            : $"Placing: {next.Name} (size {next.Size}). Orientation: {(IsVertical ? "Vertical" : "Horizontal")}.";
    }

    private void ToggleOrientation()
    {
        IsVertical = !IsVertical;

        var next = Game.GetNextPlayerShipToPlace();
        if (IsPlacing && next is not null)
        {
            StatusMessage = $"Placing: {next.Name} (size {next.Size}). Orientation: {(IsVertical ? "Vertical" : "Horizontal")}.";
        }
    }

    private void OnPlayerCellClicked(int row, int col)
    {
        // ✅ THIS is the fix: only ignore clicks when NOT placing
        if (!IsPlacing)
            return;

        var ship = Game.GetNextPlayerShipToPlace();
        if (ship is null)
        {
            StatusMessage = "All ships placed! Game will begin.";
            return;
        }

        var ok = Game.PlacePlayerShip(ship, row, col, IsVertical);
        if (!ok)
        {
            StatusMessage = "Invalid placement (overlap or off-board). Try another cell.";
            return;
        }

        var next = Game.GetNextPlayerShipToPlace();
        StatusMessage = next is null
            ? "All ships placed! Your turn to fire."
            : $"Placed! Next: {next.Name} (size {next.Size}). Orientation: {(IsVertical ? "Vertical" : "Horizontal")}.";
    }

    private void OnEnemyCellClicked(int row, int col)
    {
        if (Game.CurrentPhase != GamePhase.PlayerTurn)
            return;

        var result = Game.PlayerAttacksEnemy(row, col);
        StatusMessage = result;

        // re-render
        StateHasChanged();
    }

    private string GetCellClass(Cell cell, bool isPlayerBoard)
    {
        var cls = "board-cell";

        if (isPlayerBoard && cell.HasShip)
            cls += " cell-has-ship";

        if (cell.State == CellState.Hit)
            cls += " cell-hit";
        else if (cell.State == CellState.Miss)
            cls += " cell-miss";

        return cls;
    }

    private RenderFragment RenderCell(Cell cell) => builder =>
    {
        // Minimal visuals: hit / miss markers.
        // Ships are rendered by the ship-sprite overlay.
        if (cell.State == CellState.Miss)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "cell-miss-dot");
            builder.CloseElement();
        }
    };

    private string GetShipSpritePath(Ship ship)
    {
        // Put your PNGs here:
        // Battleship.Web/wwwroot/images/ships/
        // Example names:
        // carrier.png, battleship.png, cruiser.png, submarine.png, destroyer.png
        return ship.Name.ToLowerInvariant() switch
        {
            "carrier" => "images/ships/carrier.png",
            "battleship" => "images/ships/battleship.png",
            "cruiser" => "images/ships/cruiser.png",
            "submarine" => "images/ships/submarine.png",
            "destroyer" => "images/ships/destroyer.png",
            _ => "images/ships/carrier.png"
        };
    }

    private string GetShipSpriteStyle(Ship ship)
    {
        // Use the first placed cell as the anchor
        var anchor = ship.Positions[0];
        var minRow = ship.Positions.Min(p => p.Row);
        var minCol = ship.Positions.Min(p => p.Col);

        // Determine orientation based on positions
        var vertical = ship.Positions.Select(p => p.Col).Distinct().Count() == 1;

        var left = minCol * StepPx;
        var top = minRow * StepPx;

        var width = vertical ? CellPx : (ship.Size - 1) * StepPx + CellPx;
        var height = vertical ? (ship.Size - 1) * StepPx + CellPx : CellPx;

        return $"left:{left}px; top:{top}px; width:{width}px; height:{height}px;";
    }
}
